# Optional: choose the LLM provider used by the Intention Processor.
# Supported values:
#   ollama  - local Ollama server, no cloud key required
#   openai  - OpenAI Responses API
#   none    - skip LLM call and use the deterministic fallback DN source
LLM_PROVIDER=ollama

# Ollama defaults
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma4

# OpenAI defaults
# OPENAI_API_KEY=replace_with_your_openai_key
OPENAI_MODEL=gpt-4.1-mini
